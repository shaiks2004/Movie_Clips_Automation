# ClipMood AI Content Factory Configuration
# Copy this file to .env and fill in your values. Do not commit .env.

# Flask settings
SECRET_KEY=your_flask_secret_key_here
PORT=5000
HOST=0.0.0.0

# Database Settings
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/clipmood?retryWrites=true&w=majority

# AI API Credentials
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Local Directory Paths (Absolute or Relative to project root)
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
TRANSCRIPT_FOLDER=transcripts
SCENE_FOLDER=scenes
CLIP_FOLDER=clips
SUBTITLE_FOLDER=subtitles
METADATA_FOLDER=metadata
